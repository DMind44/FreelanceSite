# API Configuration
# Copy this to .env and fill in your values

# CORS — comma-separated origins
API_CORS_ORIGINS=["http://localhost:4321","https://yoursite.com"]

# SMTP (for email notifications)
API_SMTP_HOST=smtp.example.com
API_SMTP_PORT=587
API_SMTP_USER=
API_SMTP_PASS=

# Where to send commission notifications
API_NOTIFICATION_EMAIL=you@example.com

# Your site's production URL
API_SITE_URL=https://yoursite.com